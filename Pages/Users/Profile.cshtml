@page "{username}"
@model MiniSocialNetwork.Pages.Users.ProfileModel
@{
    ViewData["Title"] = Model.Profile?.Username + "'s Profile";
}

<div class="row">
    <div class="col-lg-4">
        @if (Model.Profile != null)
        {
            <div class="card profile-card mb-4">
                @if (!string.IsNullOrEmpty(Model.Profile.AvatarPath))
                {
                    <img src="@Model.Profile.AvatarPath" alt="Avatar" class="avatar avatar-lg mx-auto">
                }
                else
                {
                    <div class="avatar avatar-lg bg-primary text-white d-flex align-items-center justify-content-center mx-auto" style="font-size: 3rem;">
                        <i class="bi bi-person"></i>
                    </div>
                }
                <h4 class="mt-3 mb-1">@Model.Profile.Username</h4>
                @if (!string.IsNullOrEmpty(Model.Profile.FullName))
                {
                    <p class="text-muted mb-1">@Model.Profile.FullName</p>
                }
                @if (!string.IsNullOrEmpty(Model.Profile.Bio))
                {
                    <p class="small mt-2">@Model.Profile.Bio</p>
                }
                <div class="profile-stats">
                    <div class="profile-stat">
                        <div class="profile-stat-value">@Model.Profile.PostCount</div>
                        <div class="profile-stat-label">Posts</div>
                    </div>
                    <a asp-page="/Users/Followers" asp-route-username="@Model.Profile.Username" class="profile-stat text-decoration-none">
                        <div class="profile-stat-value">@Model.Profile.FollowerCount</div>
                        <div class="profile-stat-label">Followers</div>
                    </a>
                    <a asp-page="/Users/Following" asp-route-username="@Model.Profile.Username" class="profile-stat text-decoration-none">
                        <div class="profile-stat-value">@Model.Profile.FollowingCount</div>
                        <div class="profile-stat-label">Following</div>
                    </a>
                </div>

                @if (Model.IsLoggedIn && !Model.IsOwnProfile)
                {
                    <form method="post" asp-page-handler="ToggleFollow" class="mt-3">
                        <input type="hidden" name="targetUserId" value="@Model.Profile.UserId" />
                        @if (Model.IsFollowing)
                        {
                            <button type="submit" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-person-check"></i> Following
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-person-plus"></i> Follow
                            </button>
                        }
                    </form>
                }
                else if (Model.IsOwnProfile)
                {
                    <a asp-page="/Account/Profile" class="btn btn-outline-primary w-100 mt-3">
                        <i class="bi bi-pencil"></i> Edit Profile
                    </a>
                }

                <p class="small text-muted mt-3 mb-0">
                    <i class="bi bi-calendar3"></i> Joined @Model.Profile.CreatedAt?.ToString("MMMM yyyy")
                </p>
            </div>
        }
    </div>

    <div class="col-lg-8">
        <h4 class="mb-3"><i class="bi bi-file-earmark-text"></i> Posts by @Model.Profile?.Username</h4>

        @if (Model.UserPosts != null && Model.UserPosts.Any())
        {
            @foreach (var post in Model.UserPosts)
            {
                <div class="card post-card">
                    <div class="card-body">
                        <div class="post-header">
                            @if (!string.IsNullOrEmpty(post.AvatarPath))
                            {
                                <img src="@post.AvatarPath" alt="Avatar" class="avatar">
                            }
                            else
                            {
                                <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center">
                                    <i class="bi bi-person"></i>
                                </div>
                            }
                            <div>
                                <div class="post-author">@post.Username</div>
                                <div class="post-time">
                                    <i class="bi bi-clock"></i> @post.CreatedAt?.ToString("MMM dd, yyyy HH:mm")
                                </div>
                            </div>
                        </div>

                        <div class="post-content">
                            @post.Content
                        </div>

                        @if (!string.IsNullOrEmpty(post.ImagePath))
                        {
                            <img src="@post.ImagePath" alt="Post Image" class="post-image img-fluid">
                        }

                        <div class="post-actions">
                            @if (Model.IsLoggedIn)
                            {
                                <form method="post" asp-page-handler="Like" class="d-inline flex-fill">
                                    <input type="hidden" name="postId" value="@post.PostId" />
                                    <button type="submit" class="post-action-btn @(post.IsLikedByCurrentUser ? "liked" : "")">
                                        <i class="bi @(post.IsLikedByCurrentUser ? "bi-heart-fill" : "bi-heart")"></i>
                                        @post.LikeCount Likes
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="post-action-btn">
                                    <i class="bi bi-heart"></i> @post.LikeCount Likes
                                </span>
                            }
                            <span class="post-action-btn">
                                <i class="bi bi-chat"></i> @post.CommentCount Comments
                            </span>
                            <a asp-page="/Posts/Details" asp-route-id="@post.PostId" class="post-action-btn text-decoration-none">
                                <i class="bi bi-eye"></i> View
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card">
                <div class="card-body empty-state">
                    <i class="bi bi-file-earmark-x"></i>
                    <h5>No posts yet</h5>
                    <p>@Model.Profile?.Username hasn't posted anything yet.</p>
                </div>
            </div>
        }
    </div>
</div>
