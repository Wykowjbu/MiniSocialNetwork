@page "{id:int}"
@model MiniSocialNetwork.Pages.Posts.DetailsModel
@{
    ViewData["Title"] = "Post Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <a asp-page="/Index" class="btn btn-outline-secondary mb-3">
            <i class="bi bi-arrow-left"></i> Back to Feed
        </a>

        @if (Model.Post != null)
        {
            <div class="card post-card">
                <div class="card-body">
                    <div class="post-header">
                        @if (!string.IsNullOrEmpty(Model.Post.AvatarPath))
                        {
                            <img src="@Model.Post.AvatarPath" alt="Avatar" class="avatar">
                        }
                        else
                        {
                            <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center">
                                <i class="bi bi-person"></i>
                            </div>
                        }
                        <div>
                            <div class="post-author">
                                <a asp-page="/Users/Profile" asp-route-username="@Model.Post.Username" class="text-decoration-none">
                                    @Model.Post.Username
                                </a>
                            </div>
                            <div class="post-time">
                                <i class="bi bi-clock"></i> @Model.Post.CreatedAt?.ToString("MMMM dd, yyyy 'at' HH:mm")
                                @if (Model.Post.UpdatedAt.HasValue)
                                {
                                    <span class="text-muted">(edited @Model.Post.UpdatedAt?.ToString("MMM dd, yyyy HH:mm"))</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="post-content fs-5">
                        @Model.Post.Content
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Post.ImagePath))
                    {
                        <img src="@Model.Post.ImagePath" alt="Post Image" class="post-image img-fluid">
                    }

                    <div class="post-actions">
                        @if (Model.IsLoggedIn)
                        {
                            <form method="post" asp-page-handler="Like" class="d-inline flex-fill">
                                <input type="hidden" name="postId" value="@Model.Post.PostId" />
                                <button type="submit" class="post-action-btn @(Model.Post.IsLikedByCurrentUser ? "liked" : "")">
                                    <i class="bi @(Model.Post.IsLikedByCurrentUser ? "bi-heart-fill" : "bi-heart")"></i>
                                    @Model.Post.LikeCount Like@(Model.Post.LikeCount != 1 ? "s" : "")
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="post-action-btn">
                                <i class="bi bi-heart"></i> @Model.Post.LikeCount Like@(Model.Post.LikeCount != 1 ? "s" : "")
                            </span>
                        }
                        <a asp-page="/Posts/Likes" asp-route-id="@Model.Post.PostId" class="post-action-btn text-decoration-none">
                            <i class="bi bi-people"></i> View Likes
                        </a>
                        <span class="post-action-btn">
                            <i class="bi bi-chat"></i> @Model.Post.CommentCount Comment@(Model.Post.CommentCount != 1 ? "s" : "")
                        </span>
                    </div>

                    @if (Model.Post.IsOwnedByCurrentUser)
                    {
                        <div class="mt-3 pt-3 border-top">
                            <a asp-page="/Posts/Edit" asp-route-id="@Model.Post.PostId" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-page="/Posts/Delete" asp-route-id="@Model.Post.PostId" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Comments Section -->
            <div class="card mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-chat-dots"></i> Comments (@Model.Comments?.Count())</h5>
                </div>
                <div class="card-body">
                    @if (Model.IsLoggedIn)
                    {
                        <!-- Add Comment Form -->
                        <form method="post" asp-page-handler="AddComment" class="mb-4">
                            <input type="hidden" name="postId" value="@Model.Post.PostId" />
                            <div class="d-flex">
                                @if (!string.IsNullOrEmpty(Model.CurrentUserAvatar))
                                {
                                    <img src="@Model.CurrentUserAvatar" alt="Avatar" class="avatar me-3">
                                }
                                else
                                {
                                    <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center me-3">
                                        <i class="bi bi-person"></i>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <textarea name="commentContent" class="form-control" rows="2" 
                                        placeholder="Write a comment..." required></textarea>
                                </div>
                            </div>
                            <div class="text-end mt-2">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="bi bi-send"></i> Post Comment
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <a asp-page="/Account/Login">Login</a> to post a comment.
                        </div>
                    }

                    <!-- Comments List -->
                    @if (Model.Comments != null && Model.Comments.Any())
                    {
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="d-flex mb-3 pb-3 border-bottom">
                                @if (!string.IsNullOrEmpty(comment.AvatarPath))
                                {
                                    <img src="@comment.AvatarPath" alt="Avatar" class="avatar me-3">
                                }
                                else
                                {
                                    <div class="avatar bg-secondary text-white d-flex align-items-center justify-content-center me-3">
                                        <i class="bi bi-person"></i>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <div class="bg-light rounded p-2">
                                        <a asp-page="/Users/Profile" asp-route-username="@comment.Username" 
                                            class="fw-bold text-decoration-none">@comment.Username</a>
                                        <p class="mb-0 mt-1">@comment.Content</p>
                                    </div>
                                    <small class="text-muted">
                                        <i class="bi bi-clock"></i> @comment.CreatedAt?.ToString("MMM dd, yyyy HH:mm")
                                        @if (comment.IsOwnedByCurrentUser)
                                        {
                                            <form method="post" asp-page-handler="DeleteComment" class="d-inline ms-2">
                                                <input type="hidden" name="commentId" value="@comment.CommentId" />
                                                <input type="hidden" name="postId" value="@Model.Post.PostId" />
                                                <button type="submit" class="btn btn-link btn-sm text-danger p-0" 
                                                    onclick="return confirm('Delete this comment?')">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        }
                                    </small>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-chat-dots" style="font-size: 2rem;"></i>
                            <p class="mb-0">No comments yet. Be the first to comment!</p>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle me-2"></i> Post not found.
            </div>
        }
    </div>
</div>
