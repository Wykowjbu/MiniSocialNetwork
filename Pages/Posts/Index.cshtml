@page
@model MiniSocialNetwork.Pages.Posts.IndexModel
@{
    ViewData["Title"] = "My Posts";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3><i class="bi bi-file-earmark-text"></i> My Posts</h3>
            <a asp-page="/Posts/Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Create New Post
            </a>
        </div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.Posts != null && Model.Posts.Any())
        {
            @foreach (var post in Model.Posts)
            {
                <div class="card post-card">
                    <div class="card-body">
                        <div class="post-header">
                            @if (!string.IsNullOrEmpty(post.AvatarPath))
                            {
                                <img src="@post.AvatarPath" alt="Avatar" class="avatar">
                            }
                            else
                            {
                                <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center">
                                    <i class="bi bi-person"></i>
                                </div>
                            }
                            <div>
                                <div class="post-author">@post.Username</div>
                                <div class="post-time">
                                    <i class="bi bi-clock"></i> @post.CreatedAt?.ToString("MMM dd, yyyy HH:mm")
                                    @if (post.UpdatedAt.HasValue)
                                    {
                                        <span class="text-muted">(edited)</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="post-content">
                            @post.Content
                        </div>

                        @if (!string.IsNullOrEmpty(post.ImagePath))
                        {
                            <img src="@post.ImagePath" alt="Post Image" class="post-image img-fluid">
                        }

                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <div>
                                <span class="text-muted me-3">
                                    <i class="bi bi-heart-fill text-danger"></i> @post.LikeCount likes
                                </span>
                                <span class="text-muted">
                                    <i class="bi bi-chat"></i> @post.CommentCount comments
                                </span>
                            </div>
                            <div>
                                <a asp-page="/Posts/Edit" asp-route-id="@post.PostId" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-page="/Posts/Delete" asp-route-id="@post.PostId" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card">
                <div class="card-body empty-state">
                    <i class="bi bi-file-earmark-x"></i>
                    <h5>No posts yet</h5>
                    <p>Share your first thought with the community!</p>
                    <a asp-page="/Posts/Create" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> Create Your First Post
                    </a>
                </div>
            </div>
        }
    </div>
</div>
