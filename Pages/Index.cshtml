@page
@model MiniSocialNetwork.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <!-- Main Feed -->
    <div class="col-lg-8">
        @if (Model.IsLoggedIn)
        {
            <!-- Create Post Card -->
            <div class="card create-post-card mb-4">
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        <div class="d-flex align-items-start">
                            @if (!string.IsNullOrEmpty(Model.CurrentUserAvatar))
                            {
                                <img src="@Model.CurrentUserAvatar" alt="Avatar" class="avatar me-3">
                            }
                            else
                            {
                                <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center me-3">
                                    <i class="bi bi-person"></i>
                                </div>
                            }
                            <div class="flex-grow-1">
                                <textarea asp-for="NewPostContent" class="form-control mb-2" rows="2" 
                                    placeholder="What's on your mind, @Model.CurrentUsername?"></textarea>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <div>
                                <label for="NewPostImage" class="btn btn-outline-secondary btn-sm mb-0">
                                    <i class="bi bi-image"></i> Photo
                                </label>
                                <input type="file" id="NewPostImage" name="NewPostImage" accept="image/*" style="display: none;">
                                <span id="selectedFileName" class="ms-2 small text-muted"></span>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> Post
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }

        <!-- Feed Tabs -->
        <div class="card mb-3">
            <div class="card-body p-2">
                <ul class="nav nav-pills">
                    <li class="nav-item">
                        <a class="nav-link @(Model.FeedType == "all" ? "active" : "")" asp-page="/Index" asp-route-feed="all">
                            <i class="bi bi-globe"></i> All Posts
                        </a>
                    </li>
                    @if (Model.IsLoggedIn)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(Model.FeedType == "following" ? "active" : "")" asp-page="/Index" asp-route-feed="following">
                                <i class="bi bi-people"></i> Following
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.Posts != null && Model.Posts.Any())
        {
            @foreach (var post in Model.Posts)
            {
                <div class="card post-card">
                    <div class="card-body">
                        <div class="post-header">
                            <a asp-page="/Users/Profile" asp-route-username="@post.Username" class="text-decoration-none">
                                @if (!string.IsNullOrEmpty(post.AvatarPath))
                                {
                                    <img src="@post.AvatarPath" alt="Avatar" class="avatar">
                                }
                                else
                                {
                                    <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center">
                                        <i class="bi bi-person"></i>
                                    </div>
                                }
                            </a>
                            <div>
                                <a asp-page="/Users/Profile" asp-route-username="@post.Username" class="post-author text-decoration-none">
                                    @post.Username
                                </a>
                                <div class="post-time">
                                    <i class="bi bi-clock"></i> @post.CreatedAt?.ToString("MMM dd, yyyy HH:mm")
                                    @if (post.UpdatedAt.HasValue)
                                    {
                                        <span class="text-muted">(edited)</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <a asp-page="/Posts/Details" asp-route-id="@post.PostId" class="text-decoration-none text-dark">
                            <div class="post-content">
                                @post.Content
                            </div>

                            @if (!string.IsNullOrEmpty(post.ImagePath))
                            {
                                <img src="@post.ImagePath" alt="Post Image" class="post-image img-fluid">
                            }
                        </a>

                        <div class="post-actions">
                            @if (Model.IsLoggedIn)
                            {
                                <form method="post" asp-page-handler="Like" class="d-inline flex-fill">
                                    <input type="hidden" name="postId" value="@post.PostId" />
                                    <input type="hidden" name="feedType" value="@Model.FeedType" />
                                    <button type="submit" class="post-action-btn @(post.IsLikedByCurrentUser ? "liked" : "")">
                                        <i class="bi @(post.IsLikedByCurrentUser ? "bi-heart-fill" : "bi-heart")"></i>
                                        @post.LikeCount Like@(post.LikeCount != 1 ? "s" : "")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="post-action-btn">
                                    <i class="bi bi-heart"></i> @post.LikeCount Like@(post.LikeCount != 1 ? "s" : "")
                                </span>
                            }
                            <a asp-page="/Posts/Details" asp-route-id="@post.PostId" class="post-action-btn text-decoration-none">
                                <i class="bi bi-chat"></i> @post.CommentCount Comment@(post.CommentCount != 1 ? "s" : "")
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card">
                <div class="card-body empty-state">
                    @if (Model.FeedType == "following")
                    {
                        <i class="bi bi-people"></i>
                        <h5>No posts from people you follow</h5>
                        <p>Start following people to see their posts here!</p>
                        <a asp-page="/Users/Search" class="btn btn-primary">
                            <i class="bi bi-search"></i> Find People to Follow
                        </a>
                    }
                    else
                    {
                        <i class="bi bi-newspaper"></i>
                        <h5>No posts yet</h5>
                        <p>Be the first to share something!</p>
                        @if (Model.IsLoggedIn)
                        {
                            <a asp-page="/Posts/Create" class="btn btn-primary">
                                <i class="bi bi-plus-lg"></i> Create Post
                            </a>
                        }
                        else
                        {
                            <a asp-page="/Account/Login" class="btn btn-primary">
                                <i class="bi bi-box-arrow-in-right"></i> Login to Post
                            </a>
                        }
                    }
                </div>
            </div>
        }
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <div class="sidebar">
            @if (Model.IsLoggedIn && Model.CurrentProfile != null)
            {
                <div class="card profile-card mb-4">
                    <a asp-page="/Users/Profile" asp-route-username="@Model.CurrentProfile.Username" class="text-decoration-none">
                        @if (!string.IsNullOrEmpty(Model.CurrentProfile.AvatarPath))
                        {
                            <img src="@Model.CurrentProfile.AvatarPath" alt="Avatar" class="avatar avatar-lg mx-auto">
                        }
                        else
                        {
                            <div class="avatar avatar-lg bg-primary text-white d-flex align-items-center justify-content-center mx-auto" style="font-size: 3rem;">
                                <i class="bi bi-person"></i>
                            </div>
                        }
                    </a>
                    <h5 class="mt-3 mb-1">
                        <a asp-page="/Users/Profile" asp-route-username="@Model.CurrentProfile.Username" class="text-decoration-none text-dark">
                            @Model.CurrentProfile.Username
                        </a>
                    </h5>
                    <p class="text-muted small">@Model.CurrentProfile.Email</p>
                    @if (!string.IsNullOrEmpty(Model.CurrentProfile.Bio))
                    {
                        <p class="small">@Model.CurrentProfile.Bio</p>
                    }
                    <div class="profile-stats">
                        <a asp-page="/Posts/Index" class="profile-stat text-decoration-none">
                            <div class="profile-stat-value">@Model.CurrentProfile.PostCount</div>
                            <div class="profile-stat-label">Posts</div>
                        </a>
                        <a asp-page="/Users/Followers" asp-route-username="@Model.CurrentProfile.Username" class="profile-stat text-decoration-none">
                            <div class="profile-stat-value">@Model.CurrentProfile.FollowerCount</div>
                            <div class="profile-stat-label">Followers</div>
                        </a>
                        <a asp-page="/Users/Following" asp-route-username="@Model.CurrentProfile.Username" class="profile-stat text-decoration-none">
                            <div class="profile-stat-value">@Model.CurrentProfile.FollowingCount</div>
                            <div class="profile-stat-label">Following</div>
                        </a>
                    </div>
                    <a asp-page="/Account/Profile" class="btn btn-outline-primary btn-sm mt-3">
                        <i class="bi bi-pencil"></i> Edit Profile
                    </a>
                </div>
            }
            else
            {
                <div class="card mb-4">
                    <div class="card-body text-center">
                        <h5 class="mb-3">Welcome to MiniSocial!</h5>
                        <p class="text-muted">Join our community to share your thoughts and connect with others.</p>
                        <div class="d-grid gap-2">
                            <a asp-page="/Account/Login" class="btn btn-primary">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                            <a asp-page="/Account/Register" class="btn btn-success">
                                <i class="bi bi-person-plus"></i> Register
                            </a>
                        </div>
                    </div>
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <h6><i class="bi bi-info-circle"></i> About</h6>
                    <p class="small text-muted mb-0">
                        MiniSocial is a simple social network where you can share your thoughts, 
                        connect with friends, and explore interesting content.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Show selected file name
        document.getElementById('NewPostImage')?.addEventListener('change', function(e) {
            var fileName = this.files.length > 0 ? this.files[0].name : '';
            document.getElementById('selectedFileName').textContent = fileName;
        });
    </script>
}
