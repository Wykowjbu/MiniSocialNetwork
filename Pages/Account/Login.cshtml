@page
@model MiniSocialNetwork.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-container">
    <div class="card auth-card">
        <h2 class="auth-title">
            <i class="bi bi-box-arrow-in-right"></i> Login
        </h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Username" class="form-label">
                    <i class="bi bi-person"></i> Username or Email
                </label>
                <input asp-for="Input.Username" class="form-control" placeholder="Enter username or email" />
                <span asp-validation-for="Input.Username" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">
                    <i class="bi bi-lock"></i> Password
                </label>
                <input asp-for="Input.Password" class="form-control" placeholder="Enter password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </button>
            </div>
        </form>

        <hr />

        <div class="text-center">
            <p class="mb-2">Don't have an account?</p>
            <a asp-page="/Account/Register" class="btn btn-success">
                <i class="bi bi-person-plus"></i> Create New Account
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
